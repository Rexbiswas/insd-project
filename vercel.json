{
    "version": 2,
    "cleanUrls": true,
    "trailingSlash": false,
    "headers": [
        {
            "source": "/sitemap.xml",
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "application/xml"
                }
            ]
        },
        {
            "source": "/sitemap.xsl",
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "text/xsl"
                }
            ]
        },
        {
            "source": "/robots.txt",
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "text/plain"
                }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.js"
        },
        {
            "source": "/((?!api|sitemap|robots|favicon|assets|.*\\.).*)",
            "destination": "/index.html"
        }
    ]
}