{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/courses/short-term-interior-design-courses", "destination": "/courses/short-term-courses", "permanent": true },
    { "source": "/courses/short-term-interior-design-courses/", "destination": "/courses/short-term-courses", "permanent": true },
    { "source": "/courses/diploma-in-graphic-design", "destination": "/courses/graphic-designing", "permanent": true },
    { "source": "/courses/diploma-in-graphic-design/", "destination": "/courses/graphic-designing", "permanent": true },
    { "source": "/courses/diploma-in-textile-design", "destination": "/courses/textile-designing", "permanent": true },
    { "source": "/courses/diploma-in-textile-design/", "destination": "/courses/textile-designing", "permanent": true },
    { "source": "/courses/bachelors-in-graphic-design", "destination": "/courses/graphic-designing", "permanent": true },
    { "source": "/courses/bachelors-in-graphic-design/", "destination": "/courses/graphic-designing", "permanent": true },
    { "source": "/locations", "destination": "/centers-across-india", "permanent": true },
    { "source": "/locations/", "destination": "/centers-across-india", "permanent": true },
    { "source": "/courses/masters-in-animation", "destination": "/courses/animation-and-vfx", "permanent": true },
    { "source": "/courses/masters-in-animation/", "destination": "/courses/animation-and-vfx", "permanent": true },
    { "source": "/courses/diploma-in-jewellery-design", "destination": "/courses/jewellery-designing", "permanent": true },
    { "source": "/courses/diploma-in-jewellery-design/", "destination": "/courses/jewellery-designing", "permanent": true },
    { "source": "/courses/advanced-diploma-in-animation", "destination": "/courses/animation-and-vfx", "permanent": true },
    { "source": "/courses/advanced-diploma-in-animation/", "destination": "/courses/animation-and-vfx", "permanent": true },
    { "source": "/luxury-brand-management-msc", "destination": "/courses/msc-luxury-brand-management", "permanent": true },
    { "source": "/luxury-brand-management-msc/", "destination": "/courses/msc-luxury-brand-management", "permanent": true }
  ],
  "rewrites": [
    {
      "source": "/((?!api|.*\\.[a-z0-9]+$).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Credentials", "value": "true" },
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,OPTIONS,PATCH,DELETE,POST,PUT" },
        { "key": "Access-Control-Allow-Headers", "value": "X-CSRF-Token, X-Requested-With, Accept, Accept-Version, Content-Length, Content-MD5, Content-Type, Date, X-Api-Version" }
      ]
    }
  ]
}